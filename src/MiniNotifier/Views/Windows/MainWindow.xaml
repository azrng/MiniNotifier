<ui:FluentWindow
    x:Class="MiniNotifier.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MiniNotifier.Views.Controls"
    Title="MiniNotifier"
    Width="560"
    Height="640"
    MinWidth="520"
    MinHeight="600"
    Background="{StaticResource Brush.Background.App}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar
                Grid.Row="0"
                Title="MiniNotifier"
                Margin="0,0,0,14"
                ShowMinimize="False"
                ShowMaximize="False"
                ShowClose="True">
                <ui:TitleBar.Header>
                    <StackPanel Orientation="Horizontal">
                        <controls:AppLogo Width="24" Height="24" Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontFamily="{StaticResource FontFamily.Display}"
                                FontSize="15"
                                FontWeight="{StaticResource FontWeight.SemiBold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="MiniNotifier" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="轻量提醒设置" />
                        </StackPanel>
                    </StackPanel>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <Grid Grid.Row="1">
                <Grid Visibility="{Binding ContentVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        Padding="{StaticResource Thickness.CardPadding.Compact}"
                        Background="{StaticResource Brush.Background.HeroGradient}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="{StaticResource Thickness.Border.Regular}"
                        CornerRadius="{StaticResource Radius.Large}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="{Binding HeroStateText}" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="{Binding HeroHintText}" />
                            </StackPanel>

                            <Border
                                Grid.Column="1"
                                Padding="12,10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{StaticResource Brush.Background.Surface}"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="{StaticResource Thickness.Border.Regular}"
                                CornerRadius="{StaticResource Radius.Medium}">
                                <StackPanel>
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="提醒频率" />
                                    <TextBlock
                                        FontFamily="{StaticResource FontFamily.Display}"
                                        FontSize="{StaticResource FontSize.BodyLarge}"
                                        FontWeight="{StaticResource FontWeight.SemiBold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding IntervalBadgeText}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,4,0">
                            <ui:Card Margin="0,0,0,12" Padding="{StaticResource Thickness.CardPadding.Compact}">
                                <StackPanel>
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="基础设置" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="保持页面简单，常用项都集中在这里。" />

                                    <Border
                                        Margin="0,16,0,0"
                                        Padding="0,0,0,12"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock
                                                    Style="{StaticResource BodyTextStyle}"
                                                    Text="喝水提醒" />
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="关闭后不再弹窗，但托盘入口仍然保留。" />
                                            </StackPanel>

                                            <ui:ToggleSwitch
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="喝水提醒开关"
                                                IsChecked="{Binding IsReminderEnabled, Mode=TwoWay}"
                                                OffContent="关闭"
                                                OnContent="开启" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Margin="0,12,0,0"
                                        Padding="0,0,0,12"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock
                                                    Style="{StaticResource BodyTextStyle}"
                                                    Text="开机自启动" />
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{Binding AutoStartStatusText}" />
                                            </StackPanel>

                                            <ui:ToggleSwitch
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="开机自启动开关"
                                                IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                                                OffContent="关闭"
                                                OnContent="开启" />
                                        </Grid>
                                    </Border>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock
                                                Style="{StaticResource BodyTextStyle}"
                                                Text="提醒间隔" />
                                            <TextBlock
                                                Style="{StaticResource CaptionTextStyle}"
                                                Text="建议保持在 20 到 45 分钟之间。" />
                                        </StackPanel>

                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="124"
                                            HorizontalAlignment="Right"
                                            AutomationProperties.Name="提醒间隔"
                                            Maximum="240"
                                            Minimum="5"
                                            SpinButtonPlacementMode="Compact"
                                            Value="{Binding ReminderIntervalMinutes, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock
                                                Style="{StaticResource BodyTextStyle}"
                                                Text="自动关闭" />
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="提醒弹窗默认 10 秒后自动收起。" />
                                        </StackPanel>

                                        <ui:NumberBox
                                            Grid.Column="1"
                                            Width="124"
                                            HorizontalAlignment="Right"
                                            AutomationProperties.Name="自动关闭秒数"
                                            Maximum="15"
                                            Minimum="3"
                                            SpinButtonPlacementMode="Compact"
                                            Value="{Binding AutoCloseSeconds, Mode=TwoWay}" />
                                    </Grid>
                                </StackPanel>
                            </ui:Card>

                            <ui:Card Margin="0,0,0,12" Padding="{StaticResource Thickness.CardPadding.Compact}">
                                <StackPanel>
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="当前状态" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="不用展开太多信息，核心状态都放在这一块。" />

                                    <Border
                                        Margin="0,16,0,0"
                                        Padding="14,12"
                                        Background="{StaticResource Brush.Background.Surface}"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="{StaticResource Thickness.Border.Regular}"
                                        CornerRadius="{StaticResource Radius.Medium}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="下次提醒" />
                                                <TextBlock
                                                    Style="{StaticResource BodyTextStyle}"
                                                    Text="按当前设置计算的预计时间" />
                                            </StackPanel>

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource FontFamily.Display}"
                                                FontSize="{StaticResource FontSize.Title}"
                                                FontWeight="{StaticResource FontWeight.SemiBold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding NextReminderText}" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Margin="0,10,0,0"
                                        Padding="14,12"
                                        Background="{StaticResource Brush.Background.Surface}"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="{StaticResource Thickness.Border.Regular}"
                                        CornerRadius="{StaticResource Radius.Medium}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="上次提醒" />
                                                <TextBlock
                                                    Style="{StaticResource BodyTextStyle}"
                                                    Text="最近一次弹出提醒的时间" />
                                            </StackPanel>

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource FontFamily.Display}"
                                                FontSize="{StaticResource FontSize.Title}"
                                                FontWeight="{StaticResource FontWeight.SemiBold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding LastReminderText}" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Margin="0,10,0,0"
                                        Padding="14,12"
                                        Background="{StaticResource Brush.Background.Surface}"
                                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                                        BorderThickness="{StaticResource Thickness.Border.Regular}"
                                        CornerRadius="{StaticResource Radius.Medium}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="保存状态" />
                                                <TextBlock
                                                    Style="{StaticResource BodyTextStyle}"
                                                    Text="保存后这里会同步显示结果" />
                                            </StackPanel>

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontWeight="{StaticResource FontWeight.SemiBold}"
                                                Foreground="{StaticResource Brush.Text.Primary}"
                                                Text="{Binding SaveStateText}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ui:Card>
                        </StackPanel>
                    </ScrollViewer>

                    <Border
                        Grid.Row="2"
                        Margin="0,12,0,0"
                        Padding="{StaticResource Thickness.CardPadding.Compact}"
                        Background="{StaticResource Brush.Background.Glass}"
                        BorderBrush="{StaticResource Brush.Border.Subtle}"
                        BorderThickness="{StaticResource Thickness.Border.Regular}"
                        CornerRadius="{StaticResource Radius.Large}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="关闭窗口后应用仍会驻留在系统托盘中。" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{Binding ApplicationVersionText}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1" Margin="12,0,0,0" HorizontalAlignment="Right">
                                    <ui:Button
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Appearance="Secondary"
                                        Command="{Binding TestReminderCommand}"
                                        Content="立即提醒" />
                                    <ui:Button
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Appearance="Secondary"
                                        Command="{Binding TogglePauseCommand}"
                                        Content="{Binding PauseButtonText}" />
                                    <ui:Button
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Appearance="Primary"
                                        Command="{Binding SaveCommand}"
                                        Content="保存设置" />
                                </WrapPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Visibility="{Binding LoadingVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing Width="64" Height="64" IsIndeterminate="True" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="正在加载设置..." />
                        <TextBlock
                            Margin="{StaticResource Thickness.TinyGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请稍等一下，马上就好。" />
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding EmptyVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="还没有本地配置" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="已为你准备好默认节奏，可以直接继续使用。" />
                        <ui:Button
                            Margin="{StaticResource Thickness.SmallGap}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="使用默认配置" />
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding ErrorVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="配置加载失败" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请重试，或检查本地配置文件是否可访问。" />
                        <WrapPanel HorizontalAlignment="Center">
                            <ui:Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Appearance="Secondary"
                                Command="{Binding LoadCommand}"
                                Content="重试" />
                            <ui:Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Appearance="Primary"
                                Command="{Binding SwitchStateCommand}"
                                CommandParameter="Content"
                                Content="返回设置" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding NoPermissionVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前没有写入权限" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请检查配置目录权限后再试。" />
                        <ui:Button
                            Margin="{StaticResource Thickness.SmallGap}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="返回设置" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <ui:SnackbarPresenter
            x:Name="RootSnackbarPresenter"
            Margin="18"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom" />
    </Grid>
</ui:FluentWindow>
