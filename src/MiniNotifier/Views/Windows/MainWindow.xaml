<ui:FluentWindow
    x:Class="MiniNotifier.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MiniNotifier.Views.Controls"
    Title="MiniNotifier"
    Width="920"
    Height="700"
    MinWidth="860"
    MinHeight="640"
    Background="{StaticResource Brush.Background.App}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar
                Grid.Row="0"
                Title="MiniNotifier"
                ShowMinimize="False"
                ShowMaximize="False"
                ShowClose="True"
                Margin="0,0,0,18">
                <ui:TitleBar.Header>
                    <StackPanel Orientation="Horizontal">
                        <controls:AppLogo Width="28" Height="28" Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                FontFamily="{StaticResource FontFamily.Display}"
                                FontSize="15"
                                FontWeight="{StaticResource FontWeight.SemiBold}"
                                Foreground="{StaticResource Brush.Text.Primary}"
                                Text="MiniNotifier" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="喝水提醒设置" />
                        </StackPanel>
                    </StackPanel>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <Grid Grid.Row="1">
                <Grid Visibility="{Binding ContentVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ui:Card Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="{Binding HeroStateText}" />
                            <TextBlock
                                Margin="{StaticResource Thickness.TinyGap}"
                                Style="{StaticResource BodyTextStyle}"
                                Text="{Binding HeroHintText}" />
                        </StackPanel>
                    </ui:Card>

                    <ui:Card Grid.Row="1" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Margin="{StaticResource Thickness.SmallGap}"
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="提醒设置" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,18,18">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="喝水提醒" />
                                <ui:ToggleSwitch
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    AutomationProperties.Name="喝水提醒开关"
                                    IsChecked="{Binding IsReminderEnabled, Mode=TwoWay}"
                                    OffContent="关闭"
                                    OnContent="开启" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,18">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="开机自启动" />
                                <ui:ToggleSwitch
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    AutomationProperties.Name="开机自启动开关"
                                    IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                                    OffContent="关闭"
                                    OnContent="开启" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding AutoStartStatusText}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,18,18">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="提醒间隔（分钟）" />
                                <ui:NumberBox
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    AutomationProperties.Name="提醒间隔"
                                    Maximum="240"
                                    Minimum="5"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{Binding ReminderIntervalMinutes, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,18">
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="自动关闭（秒）" />
                                <ui:NumberBox
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    AutomationProperties.Name="自动关闭秒数"
                                    Maximum="15"
                                    Minimum="3"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{Binding AutoCloseSeconds, Mode=TwoWay}" />
                            </StackPanel>

                            <WrapPanel Grid.Row="3" Grid.ColumnSpan="2">
                                <ui:Button
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Appearance="Secondary"
                                    Command="{Binding TestReminderCommand}"
                                    Content="测试提醒" />
                                <ui:Button
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Appearance="Secondary"
                                    Command="{Binding TogglePauseCommand}"
                                    Content="{Binding PauseButtonText}" />
                                <ui:Button
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Appearance="Primary"
                                    Command="{Binding SaveCommand}"
                                    Content="保存设置" />
                            </WrapPanel>
                        </Grid>
                    </ui:Card>

                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ui:Card Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="下次提醒" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    FontFamily="{StaticResource FontFamily.Display}"
                                    FontSize="{StaticResource FontSize.Title}"
                                    FontWeight="{StaticResource FontWeight.SemiBold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding NextReminderText}" />
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Grid.Column="1" Style="{StaticResource CardStyle}" Padding="18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="上次提醒" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    FontFamily="{StaticResource FontFamily.Display}"
                                    FontSize="{StaticResource FontSize.Title}"
                                    FontWeight="{StaticResource FontWeight.SemiBold}"
                                    Foreground="{StaticResource Brush.Text.Primary}"
                                    Text="{Binding LastReminderText}" />
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Grid.Column="2" Style="{StaticResource CardStyle}" Padding="18">
                            <StackPanel>
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="保存状态" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.TinyGap}"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="{Binding SaveStateText}" />
                            </StackPanel>
                        </ui:Card>
                    </Grid>
                </Grid>

                <Border Visibility="{Binding LoadingVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing Width="72" Height="72" IsIndeterminate="True" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="正在加载设置..." />
                        <TextBlock
                            Margin="{StaticResource Thickness.TinyGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请稍等一下。" />
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding EmptyVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="未发现本地配置" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="已为你准备默认提醒配置，可直接继续使用。" />
                        <ui:Button
                            Margin="{StaticResource Thickness.SmallGap}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="使用默认配置继续" />
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding ErrorVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="配置加载失败" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请重试或检查本地配置文件。" />
                        <WrapPanel HorizontalAlignment="Center">
                            <ui:Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Appearance="Secondary"
                                Command="{Binding LoadCommand}"
                                Content="重试" />
                            <ui:Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Appearance="Primary"
                                Command="{Binding SwitchStateCommand}"
                                CommandParameter="Content"
                                Content="返回设置" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding NoPermissionVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前没有写入权限" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请检查配置目录权限后重试。" />
                        <ui:Button
                            Margin="{StaticResource Thickness.SmallGap}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="返回设置" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <ui:SnackbarPresenter
            x:Name="RootSnackbarPresenter"
            Margin="20"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom" />
    </Grid>
</ui:FluentWindow>
