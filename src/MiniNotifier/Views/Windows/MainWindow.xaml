<ui:FluentWindow
    x:Class="MiniNotifier.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MiniNotifier.Views.Controls"
    Title="MiniNotifier"
    Width="1180"
    Height="820"
    MinWidth="1024"
    MinHeight="720"
    Background="{StaticResource Brush.Background.App}"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Ellipse
            Width="{StaticResource Size.HeroCircle}"
            Height="{StaticResource Size.HeroCircle}"
            Margin="860,-80,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Fill="{StaticResource Brush.Brand.Glow}"
            Opacity="0.32" />

        <Ellipse
            Width="220"
            Height="220"
            Margin="-70,460,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Fill="{StaticResource Brush.Brand.Glow}"
            Opacity="0.18" />

        <Grid Margin="{StaticResource Thickness.PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="{StaticResource Thickness.SectionGap}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:AppLogo Margin="0,0,16,0" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="MiniNotifier" />
                    <TextBlock
                        Margin="{StaticResource Thickness.TinyGap}"
                        Style="{StaticResource BodyTextStyle}"
                        Text="轻量后台提醒，保持节奏，也保持一点未来感。" />
                </StackPanel>
            </Grid>

            <ui:Card Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="界面状态预览" />
                    <TextBlock
                        Margin="{StaticResource Thickness.TinyGap}"
                        Style="{StaticResource CaptionTextStyle}"
                        Text="阶段 1 保留 loading / empty / error / no-permission 预览入口，方便后续联调。" />
                    <WrapPanel Margin="{StaticResource Thickness.SmallGap}">
                        <ui:Button
                            Style="{StaticResource ToolbarButtonStyle}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="默认态" />
                        <ui:Button
                            Style="{StaticResource ToolbarButtonStyle}"
                            Appearance="Secondary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Loading"
                            Content="Loading" />
                        <ui:Button
                            Style="{StaticResource ToolbarButtonStyle}"
                            Appearance="Secondary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Empty"
                            Content="Empty" />
                        <ui:Button
                            Style="{StaticResource ToolbarButtonStyle}"
                            Appearance="Secondary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Error"
                            Content="Error" />
                        <ui:Button
                            Style="{StaticResource ToolbarButtonStyle}"
                            Appearance="Secondary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="NoPermission"
                            Content="No Permission" />
                    </WrapPanel>
                </StackPanel>
            </ui:Card>

            <Grid Grid.Row="2">
                <Grid Visibility="{Binding ContentVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1.3*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Border Margin="{StaticResource Thickness.SectionGap}" Style="{StaticResource GlassPanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="今日节奏" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="{Binding HeroStateText}" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.SmallGap}"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding HeroHintText}" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        FontFamily="{StaticResource FontFamily.Display}"
                                        FontSize="{StaticResource FontSize.BodyLarge}"
                                        FontWeight="{StaticResource FontWeight.SemiBold}"
                                        Foreground="{StaticResource Brush.Brand.Primary}"
                                        Text="{Binding IntervalBadgeText}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="下一次提醒" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        FontFamily="{StaticResource FontFamily.Display}"
                                        FontSize="{StaticResource FontSize.Hero}"
                                        FontWeight="{StaticResource FontWeight.Bold}"
                                        Foreground="{StaticResource Brush.Text.Primary}"
                                        Text="{Binding NextReminderText}" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.SmallGap}"
                                        Style="{StaticResource BodyTextStyle}"
                                        Text="{Binding SaveStateText}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <ui:Card Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.ColumnSpan="2"
                                    Margin="{StaticResource Thickness.SmallGap}"
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="提醒设置" />

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,16">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="喝水提醒" />
                                    <ui:ToggleSwitch
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        AutomationProperties.Name="喝水提醒开关"
                                        IsChecked="{Binding IsReminderEnabled, Mode=TwoWay}"
                                        OffContent="关闭"
                                        OnContent="开启" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="开机自启动" />
                                    <ui:ToggleSwitch
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        AutomationProperties.Name="开机自启动开关"
                                        IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                                        OffContent="关闭"
                                        OnContent="开启" />
                                    <TextBlock
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="{Binding AutoStartStatusText}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,16">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="提醒间隔" />
                                    <ui:NumberBox
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        AutomationProperties.Name="提醒间隔"
                                        Maximum="240"
                                        Minimum="5"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{Binding ReminderIntervalMinutes, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,16">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="自动关闭" />
                                    <ui:NumberBox
                                        Margin="{StaticResource Thickness.TinyGap}"
                                        AutomationProperties.Name="自动关闭秒数"
                                        Maximum="15"
                                        Minimum="3"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{Binding AutoCloseSeconds, Mode=TwoWay}" />
                                </StackPanel>

                                <WrapPanel Grid.Row="3" Grid.ColumnSpan="2">
                                    <ui:Button
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Appearance="Secondary"
                                        Command="{Binding TestReminderCommand}"
                                        Content="测试提醒" />
                                    <ui:Button
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Appearance="Secondary"
                                        Command="{Binding TogglePauseCommand}"
                                        Content="{Binding PauseButtonText}" />
                                    <ui:Button
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        Appearance="Primary"
                                        Command="{Binding SaveCommand}"
                                        Content="保存设置" />
                                </WrapPanel>
                            </Grid>
                        </ui:Card>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <ui:Card Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前状态" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.SmallGap}"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="这里是为最终版保留的状态摘要卡片，帮助你快速浏览当前运行状态。" />

                                <Border Margin="{StaticResource Thickness.SmallGap}" Style="{StaticResource GlassPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="上次提醒" />
                                        <TextBlock
                                            Margin="{StaticResource Thickness.TinyGap}"
                                            FontFamily="{StaticResource FontFamily.Display}"
                                            FontSize="{StaticResource FontSize.Title}"
                                            FontWeight="{StaticResource FontWeight.SemiBold}"
                                            Text="{Binding LastReminderText}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="{StaticResource Thickness.SmallGap}" Style="{StaticResource GlassPanelStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="保存状态" />
                                        <TextBlock
                                            Margin="{StaticResource Thickness.TinyGap}"
                                            Style="{StaticResource BodyTextStyle}"
                                            Text="{Binding SaveStateText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="托盘说明" />
                                <TextBlock
                                    Margin="{StaticResource Thickness.SmallGap}"
                                    Style="{StaticResource BodyTextStyle}"
                                    Text="关闭窗口后应用仍会常驻托盘。单击托盘图标可重新打开设置，右键菜单支持立即提醒、暂停/恢复提醒和退出。" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </Grid>

                <Border Visibility="{Binding LoadingVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing Width="80" Height="80" IsIndeterminate="True" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="正在同步你的提醒空间..." />
                        <TextBlock
                            Margin="{StaticResource Thickness.TinyGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="稍等一下，Mock 配置正在准备中。" />
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding EmptyVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="还没有发现你的本地提醒配置" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="已为你准备好默认节奏：每 30 分钟提醒一次，5 秒自动关闭。" />
                        <ui:Button
                            Margin="{StaticResource Thickness.SmallGap}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="使用默认配置继续" />
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding ErrorVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="配置加载失败" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="请检查配置文件或重试。阶段 1 这里用来预览错误态视觉。" />
                        <WrapPanel HorizontalAlignment="Center">
                            <ui:Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Appearance="Secondary"
                                Command="{Binding LoadCommand}"
                                Content="重试" />
                            <ui:Button
                                Style="{StaticResource ToolbarButtonStyle}"
                                Appearance="Primary"
                                Command="{Binding SwitchStateCommand}"
                                CommandParameter="Content"
                                Content="返回默认态" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Visibility="{Binding NoPermissionVisibility}" Style="{StaticResource GlassPanelStyle}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="当前没有写入配置的权限" />
                        <TextBlock
                            Margin="{StaticResource Thickness.SmallGap}"
                            Style="{StaticResource BodyTextStyle}"
                            Text="正式接入时会映射到真实权限错误；这里先保留只读界面预览。" />
                        <ui:Button
                            Margin="{StaticResource Thickness.SmallGap}"
                            Appearance="Primary"
                            Command="{Binding SwitchStateCommand}"
                            CommandParameter="Content"
                            Content="返回默认态" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <ui:SnackbarPresenter
            x:Name="RootSnackbarPresenter"
            Margin="{StaticResource Thickness.PagePadding}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom" />
    </Grid>
</ui:FluentWindow>
