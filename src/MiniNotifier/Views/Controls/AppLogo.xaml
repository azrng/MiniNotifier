<UserControl
    x:Class="MiniNotifier.Views.Controls.AppLogo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="{StaticResource Size.Logo.Large}"
    Height="{StaticResource Size.Logo.Large}">
    <Grid>
        <Border
            Background="{StaticResource Brush.Brand.Gradient}"
            BorderBrush="{StaticResource Brush.Brand.Glow}"
            BorderThickness="{StaticResource Thickness.Border.Regular}"
            CornerRadius="{StaticResource Radius.XLarge}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{StaticResource FontFamily.Display}"
                FontSize="{StaticResource FontSize.Title}"
                FontWeight="{StaticResource FontWeight.Bold}"
                Foreground="{StaticResource Brush.Text.Inverse}"
                Text="MN" />
        </Border>
        <Ellipse
            Width="{StaticResource Size.Logo.Glow}"
            Height="{StaticResource Size.Logo.Glow}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Fill="{StaticResource Brush.Brand.Glow}"
            Opacity="0.7" />
    </Grid>
</UserControl>
