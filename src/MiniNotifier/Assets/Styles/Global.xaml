<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Display}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Hero}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.Bold}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Display}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Title}" />
        <Setter Property="FontWeight" Value="{StaticResource FontWeight.SemiBold}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Default}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Default}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Tertiary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardStyle" TargetType="ui:Card">
        <Setter Property="Margin" Value="{StaticResource Thickness.SectionGap}" />
        <Setter Property="Padding" Value="{StaticResource Thickness.CardPadding}" />
    </Style>

    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Background.Glass}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="{StaticResource Thickness.Border.Regular}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
        <Setter Property="Padding" Value="{StaticResource Thickness.CardPadding}" />
    </Style>

    <Style x:Key="ToolbarButtonStyle" TargetType="ui:Button">
        <Setter Property="Margin" Value="{StaticResource Thickness.TinyGap}" />
        <Setter Property="Padding" Value="{StaticResource Thickness.ButtonPadding}" />
        <Setter Property="MinWidth" Value="{StaticResource Size.PreviewButtonWidth}" />
    </Style>
</ResourceDictionary>
