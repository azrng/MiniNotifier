<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.Brand.Primary">#4C84F0</Color>
    <Color x:Key="Color.Brand.Secondary">#6FC3FF</Color>
    <Color x:Key="Color.Brand.Deep">#1E3A8A</Color>
    <Color x:Key="Color.Surface">#F8FBFF</Color>
    <Color x:Key="Color.Surface.Elevated">#FCFEFF</Color>
    <Color x:Key="Color.Surface.Glass">#E8FFFFFF</Color>
    <Color x:Key="Color.Border.Subtle">#24FFFFFF</Color>
    <Color x:Key="Color.Text.Primary">#0F172A</Color>
    <Color x:Key="Color.Text.Secondary">#475569</Color>
    <Color x:Key="Color.Text.Tertiary">#64748B</Color>
    <Color x:Key="Color.Text.Inverse">#F8FAFC</Color>
    <Color x:Key="Color.Success">#16A34A</Color>
    <Color x:Key="Color.Warning">#D97706</Color>
    <Color x:Key="Color.Error">#DC2626</Color>

    <SolidColorBrush x:Key="Brush.Background.App" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.Background.Surface" Color="{StaticResource Color.Surface.Elevated}" />
    <SolidColorBrush x:Key="Brush.Background.Glass" Color="{StaticResource Color.Surface.Glass}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />
    <SolidColorBrush x:Key="Brush.Text.Tertiary" Color="{StaticResource Color.Text.Tertiary}" />
    <SolidColorBrush x:Key="Brush.Text.Inverse" Color="{StaticResource Color.Text.Inverse}" />
    <SolidColorBrush x:Key="Brush.Status.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Status.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Status.Error" Color="{StaticResource Color.Error}" />
    <SolidColorBrush x:Key="Brush.Brand.Primary" Color="{StaticResource Color.Brand.Primary}" />
    <SolidColorBrush x:Key="Brush.Brand.Glow" Color="#3D6FC3FF" />

    <LinearGradientBrush x:Key="Brush.Brand.Gradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource Color.Brand.Primary}" />
        <GradientStop Offset="1" Color="{StaticResource Color.Brand.Deep}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Background.HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#F1F7FF" />
        <GradientStop Offset="1" Color="#E9F5FF" />
    </LinearGradientBrush>
</ResourceDictionary>
