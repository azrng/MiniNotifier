<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniNotifier.Avalonia.ViewModels"
        x:Class="MiniNotifier.Avalonia.Views.ReminderWindow"
        x:DataType="vm:ReminderWindowViewModel"
        Width="380"
        Height="220"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Topmost="True"
        WindowStartupLocation="Manual">
  <Border Margin="16"
          Padding="{StaticResource Thickness.CardPadding}"
          Background="{StaticResource Brush.Background.Glass}"
          BorderBrush="{StaticResource Brush.Border.Subtle}"
          BorderThickness="1"
          CornerRadius="{StaticResource Radius.Large}">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
        <Border Width="42" Height="42" CornerRadius="{StaticResource Radius.Medium}" Background="{StaticResource Brush.Background.Surface}">
          <Image Width="22" Height="22" Source="/Assets/Icons/AppIcon.ico" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock Classes="caption" Text="{Binding Title}" />
          <TextBlock Classes="hero-title" Text="{Binding Headline}" TextWrapping="Wrap" />
        </StackPanel>
      </Grid>

      <TextBlock Grid.Row="1"
                 Classes="body"
                 Text="{Binding Message}"
                 TextWrapping="Wrap"
                 MaxHeight="96" />

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <TextBlock Classes="caption" Text="{Binding CountdownText}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Classes="secondary-action" Command="{Binding DismissCommand}" Content="关闭" />
      </Grid>
    </Grid>
  </Border>
</Window>
