<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Window">
    <Setter Property="FontFamily" Value="Segoe UI,Microsoft YaHei UI" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.headline">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.hero-title">
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.body">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="LineHeight" Value="22" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Tertiary}" />
  </Style>

  <Style Selector="TextBlock.metric">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.metric-small">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
  </Style>

  <Style Selector="Border.hero-card">
    <Setter Property="Background" Value="{StaticResource Brush.Background.HeroGradient}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
  </Style>

  <Style Selector="Border.panel-card">
    <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
  </Style>

  <Style Selector="Border.metric-card">
    <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
  </Style>

  <Style Selector="Border.state-row">
    <Setter Property="Background" Value="{StaticResource Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
  </Style>

  <Style Selector="Border.footer-card">
    <Setter Property="Background" Value="{StaticResource Brush.Background.Glass}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
  </Style>

  <Style Selector="Border.state-card">
    <Setter Property="Background" Value="{StaticResource Brush.Background.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource Radius.Large}" />
    <Setter Property="Padding" Value="{StaticResource Thickness.CardPadding}" />
  </Style>

  <Style Selector="Button.primary-action">
    <Setter Property="Background" Value="#275FD6" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Padding" Value="18,12" />
  </Style>

  <Style Selector="Button.secondary-action">
    <Setter Property="Background" Value="{StaticResource Brush.Background.App}" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="18,12" />
  </Style>

  <Style Selector="Button.quiet-action">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="16,10" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Padding" Value="12,10" />
  </Style>
</Styles>
